{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.venv/Scripts/python.exe",
            "args": ["${CLAUDE_PROJECT_DIR}/scripts/check.py"],
            "timeout": 60,
            "statusMessage": "Running FitFindr compliance/security checks"
          }
        ]
      }
    ]
  }
}
